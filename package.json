{
  "name": "emtees-academy-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "lint": "concurrently \"npm run lint --workspace=client\" \"npm run lint --workspace=server\"",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "fast-check": "^4.7.0",
    "prettier": "^3.7.4",
    "vitest": "^4.0.16"
  }
}
